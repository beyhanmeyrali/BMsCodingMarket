# Honcho Bridge Configuration
# Copy this file to .env and customize for your project

# ========== Core Configuration ==========
# Workspace ID (uses folder name if not specified)
HONCHO_WORKSPACE=my-project

# Peer ID (uses git username if not specified)
HONCHO_PEER_ID=user

# Honcho server URL (local Docker instance)
HONCHO_BASE_URL=http://localhost:8000

# ========== Privacy Controls ==========
# Enable automatic redaction of sensitive information
HONCHO_PRIVACY_ENABLED=true

# Comma-separated list of patterns to redact
# Options: email, api_key, password, ip, aws_key, github_token, slack_token, jwt, uuid, credit_card
HONCHO_REDACT_PATTERNS=email,api_key,password,ip

# Allow session-level opt-out from memory storage
HONCHO_SESSION_OPT_OUT=false

# ========== Critical Fact Detection ==========
# Patterns that trigger immediate storage (bypasses deriver latency)
HONCHO_CRITICAL_PATTERNS=remember:|never forget|important:|NOTE:|KEY FACT:|ALWAYS:|NEVER:

# Enable immediate storage for critical facts
HONCHO_IMMEDIATE_STORE=true

# ========== Tool Usage Tracking ==========
# Track which tools are used for learning patterns
HONCHO_TRACK_TOOL_USAGE=true

# ========== Claude Native Memory Sync ==========
# Sync mode: none, honcho-to-claude, claude-to-honcho, bidirectional
HONCHO_CLAUDE_SYNC_MODE=bidirectional

# Sync on session start
HONCHO_SYNC_ON_SESSION_START=true

# ========== Memory Hierarchy ==========
# Memory level: global, project, file, context
HONCHO_MEMORY_LEVEL=project

# Project scope: workspace, folder, custom
HONCHO_PROJECT_SCOPE=workspace

# ========== Search Configuration ==========
# Semantic search threshold (0.0 to 1.0)
HONCHO_SEARCH_THRESHOLD=0.7

# Default time range for searches (e.g., 30d, 7d, 1h)
HONCHO_SEARCH_DEFAULT_AFTER=30d

# ========== Health Dashboard ==========
# Threshold for considering observations as stale (days)
HONCHO_STALE_THRESHOLD_DAYS=30

# Warning threshold for deriver lag (minutes)
HONCHO_DERIVER_LAG_WARNING_MINUTES=5

# Enable automatic cleanup of stale observations
HONCHO_AUTO_CLEANUP_STALE=false

# ========== Logging ==========
# Enable debug logging
HONCHO_DEBUG=false

# Log file path (empty for stdout)
HONCHO_LOG_FILE=
