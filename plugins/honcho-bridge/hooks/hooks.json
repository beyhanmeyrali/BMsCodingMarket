{
  "description": "honcho-bridge: Local Honcho integration with automatic memory hooks.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/load_memory.py\"",
            "async": false
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/save_messages.py\"",
            "async": true
          }
        ]
      }
    ]
  }
}
