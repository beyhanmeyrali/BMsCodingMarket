# Honcho Bridge Configuration
# Copy this to your project root as .env or set these as environment variables

# Workspace ID for Honcho (creates/uses this workspace)
HONCHO_WORKSPACE=my-project

# Your peer ID (how you're identified in the memory system)
HONCHO_PEER_ID=user

# Local Honcho API URL (Docker)
HONCHO_BASE_URL=http://localhost:8000
